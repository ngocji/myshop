<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="RealtimeBlurView">
        <attr name="realtimeBlurRadius" format="dimension" />
        <attr name="realtimeDownsampleFactor" format="float" />
        <attr name="realtimeOverlayColor" format="color" />
    </declare-styleable>

    <declare-styleable name="RoundRectBlurView">
        <attr name="allRadius" format="dimension" />
        <attr name="topLeftRadius" format="dimension" />
        <attr name="topRightRadius" format="dimension" />
        <attr name="bottomLeftRadius" format="dimension" />
        <attr name="bottomRightRadius" format="dimension" />
        <attr name="enabledStroke" format="boolean" />
    </declare-styleable>

    <declare-styleable name="ToggleCountView">
        <attr name="tg_hide_when_counting_zero" format="boolean" />
        <attr name="tg_use_expanded_view" format="boolean" />
    </declare-styleable>

    <declare-styleable name="ProgressItemView">
        <attr name="progressValue" format="integer"/>
        <attr name="indicatorColor" format="color"/>
        <attr name="trackColor" format="color"/>
    </declare-styleable>
    
    <declare-styleable name="CustomEdittext">
        <attr name="cs_title" format="string" />
        <attr name="cs_hint" format="string" />
        <attr name="cs_text" format="string" />
        <attr name="cs_image_start" format="reference" />
    </declare-styleable>
</resources>