<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="defaultButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="cornerRadius">@dimen/default_radius</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/colorRipple</item>
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">15dp</item>
    </style>

    <style name="defaultButton.cancelable">
        <item name="backgroundTint">@color/colorCancelable</item>
    </style>

    <style name="defaultButton.waring">
        <item name="backgroundTint">@color/colorWaring</item>
    </style>

    <style name="fontMedium"></style>

    <style name="fontBold">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="fontSemiBold">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ShapeAppearanceOverlay.CornerSize16" parent="">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="toggleToolbarIconStyle">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
    </style>

    <style name="dialogTitleStyle" parent="fontBold">
        <item name="android:textSize">20sp</item>
    </style>
</resources>