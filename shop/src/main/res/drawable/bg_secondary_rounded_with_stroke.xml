<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="-90"
                android:centerColor="#0DFFFFFF"
                android:endColor="#1AFFFFFF"
                android:startColor="#66FFFFFF"
                android:type="linear" />
            <corners android:radius="@dimen/default_radius" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape>
            <solid android:color="#1A1D1C" />
            <corners android:radius="@dimen/default_radius" />
        </shape>
    </item>
</layer-list>