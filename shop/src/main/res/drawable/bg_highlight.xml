<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/colorRipple">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorRipple" />
            <corners android:radius="@dimen/default_radius" />
        </shape>
    </item>

    <item android:id="@android:id/background">
        <layer-list>
            <item>
                <shape>
                    <gradient
                        android:angle="-90"
                        android:centerColor="#0DFFFFFF"
                        android:endColor="#1AFFFFFF"
                        android:startColor="#66FFFFFF"
                        android:type="linear" />
                    <corners android:radius="@dimen/default_radius" />
                </shape>
            </item>
            <item
                android:bottom="1dp"
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">
                <shape>
                    <solid android:color="#313433" />
                    <corners android:radius="@dimen/default_radius" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>